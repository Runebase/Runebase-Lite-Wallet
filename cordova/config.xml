<?xml version='1.0' encoding='utf-8'?>
<widget android-versionCode="222" id="io.runebase.runebaselitewallet" version="2.2.2" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>Runebase Lite Wallet</name>
    <description>A lightweight wallet and transaction signing client for the Runebase network</description>
    <author email="support@runebase.io" href="https://www.runebase.io">Bago</author>
    <content src="popup.html" />
    <access origin="https://www.runesx.xyz" />
    <access origin="https://discord.runebase.io" />
    <access origin="https://explorer.runebase.io" />
    <access origin="https://testnet.runebase.io" />
    <access origin="https://electrum1.runebase.io:50004" />
    <access origin="https://electrum2.runebase.io:50004" />
    <access origin="https://electrum3.runebase.io:50004" />
    <access origin="https://electrum4.runebase.io:50004" />
    <access origin="https://testelectrum1.runebase.io:50004" />
    <access origin="https://testelectrum2.runebase.io:50004" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-navigation href="https://www.runesx.xyz/*" />
    <allow-navigation href="https://discord.runebase.io/*" />
    <allow-navigation href="https://explorer.runebase.io/*" />
    <allow-navigation href="https://testnet.runebase.io/*" />
    <platform name="android">
        <preference name="AndroidExtraFilesystems" value="files,files-external,documents,sdcard,cache,cache-external,root" />
        <preference name="AndroidPersistentFileLocation" value="internal" />
        <icon density="hdpi" src="resources/android/icon/drawable-hdpi-icon.png" />
        <icon density="ldpi" src="resources/android/icon/drawable-ldpi-icon.png" />
        <icon density="mdpi" src="resources/android/icon/drawable-mdpi-icon.png" />
        <icon density="xhdpi" src="resources/android/icon/drawable-xhdpi-icon.png" />
        <icon density="xxhdpi" src="resources/android/icon/drawable-xxhdpi-icon.png" />
        <icon density="xxxhdpi" src="resources/android/icon/drawable-xxxhdpi-icon.png" />
        <preference name="FadeSplashScreen" value="false" />
        <preference name="AndroidWindowSplashScreenBackground" value="#8FD8D8" />
        <preference name="AndroidWindowSplashScreenAnimatedIcon" value="res/screen/android/splashscreen.png" />
    </platform>
    <platform name="ios">
