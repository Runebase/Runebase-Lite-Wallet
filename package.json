    "@babel/plugin-proposal-optional-chaining": "^7.21.0",
    "@babel/plugin-syntax-optional-chaining": "^7.8.3",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@ceoimon/typed-css-modules": "^0.1.0",
    "@eslint/js": "^9.0.0",
