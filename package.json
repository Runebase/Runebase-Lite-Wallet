{
  "name": "Runebase-Lite-Wallet",
  "description": "LightWeight wallet for the Runebase blockchain",
  "author": {
    "name": "Bago",
    "email": "support@runebase.io"
  },
  "version": "1.7.3",
  "private": true,
  "scripts": {
    "clean": "rm -rf dist",
    "start": "yarn clean && mkdir dist && ./scripts/create-empty-thunk.sh && webpack --progress --config webpack.dev.config.js --watch --devtool source-map & yarn css-types -w",
    "dev": "webpack --progress --config webpack.dev.config.js --watch --devtool source-map & yarn css-types -w",
    "dev:browser": "mkdir -p dist && ./scripts/create-empty-thunk.sh && webpack serve --progress --config webpack.dev-browser.config.js",
    "dev:ext": "yarn clean && mkdir -p dist && ./scripts/create-empty-thunk.sh && webpack --progress --config webpack.dev.config.js --watch --devtool source-map & yarn css-types -w & web-ext run --source-dir dist --target=chromium --start-url about:debugging",
    "release:patch": "./build.sh patch",
    "release:minor": "./build.sh minor",
    "release:major": "./build.sh major",
    "build:cordova:release": "cd cordova && cordova build android --release",
    "start:cordova": "cd cordova && cordova run android",
    "start:electron": "electron ./electron/main.js",
    "css-types": "tcm src",
    "postinstall": "npx tcm src",
    "lint": "eslint src/",
    "lint-fix": "eslint src/ --fix",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": "npm run lint-fix"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
