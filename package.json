{
  "name": "Runebase-Lite-Wallet",
  "description": "LightWeight wallet for the Runebase blockchain",
  "author": {
    "name": "Bago",
    "email": "support@runebase.io"
  },
  "version": "2.2.2",
  "homepage": "https://github.com/runebase/runebase-lite-wallet",
  "private": true,
  "scripts": {
    "clean": "rm -rf dist",
    "dev": "vite",
    "dev:browser": "vite",
    "dev:ext": "npm run build:ext -- --watch & web-ext run --source-dir dist --target=chromium --start-url about:debugging",
    "build": "vite build --config vite.config.extension.ts",
    "build:ext": "vite build --config vite.config.extension.ts",
    "release:patch": "./scripts/bump-version.sh patch",
    "release:minor": "./scripts/bump-version.sh minor",
    "release:major": "./scripts/bump-version.sh major",
    "build:cordova:release": "cd cordova && cordova build android --release",
    "start:cordova": "cd cordova && cordova run android",
    "start:electron": "electron ./electron/main.js",
    "lint": "eslint src/",
    "lint-fix": "eslint src/ --fix",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": "npm run lint-fix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.1.40",
    "@types/classnames": "^2.3.4",
    "@types/create-hash": "^1.2.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "terser": "^5.46.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vm-browserify": "^1.1.2",
    "web-ext-types": "^3.2.1"
  },
  "dependencies": {
    "@bitcoinerlab/secp256k1": "^1.2.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@mui/system": "^9.0.0",
    "@reduxjs/toolkit": "^2.11.2",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.6.0",
    "@types/scryptsy": "^2.0.0",
    "@types/secp256k1": "^4.0.7",
    "assert": "^2.1.0",
    "bignumber.js": "^10.0.2",
    "bip32": "^5.0.1",
    "bip38": "^3.1.1",
    "bip39": "^3.1.0",
    "bitcoinjs-lib": "^7.0.1",
    "browserify-zlib": "^0.2.0",
    "buffer": "^6.0.3",
    "classnames": "^2.5.1",
    "coinselect": "^3.1.13",
    "create-hash": "^1.2.0",
    "crypto-browserify": "^3.12.1",
    "dexie": "^4.4.2",
    "ecpair": "^3.0.1",
    "electron-progressbar": "^2.2.1",
    "electron-updater": "^6.8.3",
    "ethjs-abi": "^0.2.1",
    "events": "^3.3.0",
    "https-browserify": "^1.0.0",
    "lodash": "^4.18.1",
    "moment": "^2.30.1",
    "process": "^0.11.10",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-redux": "^9.2.0",
    "react-router": "^7.14.1",
    "scryptsy": "^2.1.0",
    "secp256k1": "^5.0.1",
    "stream-browserify": "^3.0.0",
    "stream-http": "^3.2.0",
    "tss-react": "^4.9.20",
    "url": "^0.11.4",
    "wif": "^5.0.0"
  },
  "main": "electron/main.js"
}
